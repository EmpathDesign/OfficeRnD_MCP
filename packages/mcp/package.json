{
  "name": "@officernd/mcp",
  "version": "0.1.0",
  "description": "OfficeRnD Model Context Protocol server — exposes all OfficeRnD resources as AI tools",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "officernd-mcp": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist *.tsbuildinfo",
    "start": "node ./dist/bin/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@officernd/core": "0.1.0",
    "@officernd/sdk": "0.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}

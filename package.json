{
  "name": "officernd-mcp-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OfficeRnD Model Context Protocol (MCP) server, SDK, and VS Code extension.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/sdk",
    "packages/core",
    "packages/mcp",
    "packages/vscode"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

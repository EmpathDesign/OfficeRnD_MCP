{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "paths": {
      "@officernd/sdk": ["../sdk/src/index.ts"],
      "@officernd/core": ["../core/src/index.ts"]
    }
  },
  "references": [{ "path": "../sdk" }, { "path": "../core" }],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
